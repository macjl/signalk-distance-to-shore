{
  "name": "signalk-distance-to-shore",
  "version": "0.1.0",
  "description": "Signal K plugin that publishes distance to the nearest known coastline.",
  "main": "index.js",
  "scripts": {
    "test": "node --test",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "npm test",
    "fetch:coastline": "node tools/fetch-osm-coastline.js",
    "fetch:coastline:bbox": "node tools/fetch-overpass-coastline.js",
    "build:coast-db": "node tools/build-coast-db.js",
    "build:coast-db:chunked": "node tools/build-coast-db-chunked.js",
    "build:coast-pmtiles": "node tools/build-coast-pmtiles.js"
  },
  "files": [
    "index.js",
    "lib",
    "tools",
    "public",
    "data/charts",
    "data/coast-db/cote-azur",
    "data/coast-db/mediterranean",
    "data/rough-antibes-v1.json",
    "README.md",
    "CHANGELOG.md",
    "NOTICE.md"
  ],
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-category-utility",
    "signalk",
    "navigation",
    "coast",
    "coastline",
    "shore",
    "distance",
    "grounding",
    "safety",
    "openstreetmap"
  ],
  "author": "Jean-Laurent Girod (@macjl)",
  "license": "Apache-2.0",
  "homepage": "https://github.com/macjl/signalk-distance-to-shore#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/macjl/signalk-distance-to-shore.git"
  },
  "bugs": {
    "url": "https://github.com/macjl/signalk-distance-to-shore/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@mapbox/vector-tile": "^3.0.0",
    "geojson-vt": "^4.0.3",
    "pbf": "^5.1.0",
    "pmtiles": "^4.4.1",
    "vt-pbf": "^3.1.3"
  },
  "devDependencies": {
    "shapefile": "^0.6.6",
    "yauzl": "^3.3.2"
  },
  "signalk-plugin-enabled-by-default": false,
  "signalk": {
    "displayName": "Distance To Shore",
    "appIcon": "./public/icon.svg"
  },
  "dependencies": {
    "@mapbox/vector-tile": "^3.0.0",
    "geojson-vt": "^4.0.3",
    "pbf": "^5.1.0",
    "pmtiles": "^4.4.1",
    "vt-pbf": "^3.1.3"
  }
}
